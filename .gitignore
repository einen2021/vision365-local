# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
.next/

# production
/build

# local desktop dev / test runtime data
.pkg-cache/
.vision365-dev/
.vision365-dev-test/
.vision365-prod-test/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tauri / rust
src-tauri/target/

# desktop bundle (generated by npm run desktop:server:pkg)
src-tauri/resources/server/
src-tauri/resources/node/
src-tauri/resources/db-seed.json

# desktop frontend build temp (api routes moved aside during static export)
src/app/_api_web_only/

# desktop server compile output
desktop-server/dist/
desktop-server/src/workers/firePanelWorker.runtime.cjs

# windows installers (if copied out of target/)
*.msi

# os / editor
Thumbs.db
Desktop.ini
.cursor/

# local sqlite (if created in repo during dev)
*.sqlite
*.sqlite3
desktop-server/**/*.db

# local JSON db write artifacts
data/db.json.tmp
data/db.json.lock

# embedded MongoDB runtime data
data/mongodb/
src-tauri/resources/mongodb/
