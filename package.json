{
  "name": "vision365-minimal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "desktop:server": "npx tsx desktop-server/src/index.ts",
    "desktop:server:build": "node scripts/build-desktop-server.mjs",
    "desktop:server:pkg": "node scripts/build-desktop-server-pkg.mjs",
    "desktop:mongodb:download": "node scripts/download-mongodb.mjs",
    "desktop:dev:frontend": "next dev --webpack -p 3000",
    "desktop:dev": "concurrently -k -n next,api -c blue,green \"npm run desktop:dev:frontend\" \"npm run desktop:server\"",
    "desktop:build:frontend": "node scripts/desktop-build-frontend.mjs",
    "desktop:build": "npm run desktop:server:pkg && npm run desktop:build:frontend && cd src-tauri && npx tauri build",
    "desktop:build:windows": "scripts\\desktop-build-windows.cmd",
    "desktop:build:macos": "npm run desktop:server:build && npm run desktop:build:frontend && cd src-tauri && npx tauri build --target aarch64-apple-darwin",
    "desktop:build:linux": "npm run desktop:server:build && npm run desktop:build:frontend && cd src-tauri && npx tauri build --target x86_64-unknown-linux-gnu",
    "db:migrate": "npx tsx desktop-server/src/db/migrate-cli.ts",
    "tauri": "cd src-tauri && npx tauri"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-toast": "^1.2.16",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.2",
    "@tauri-apps/plugin-fs": "^2.2.2",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "extract-zip": "^2.0.1",
    "hono": "^4.8.3",
    "lucide-react": "^1.17.0",
    "mongodb": "^7.3.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "react-secure-storage": "^1.3.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@yao-pkg/pkg": "^6.20.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "mongodb-memory-server": "^11.2.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
